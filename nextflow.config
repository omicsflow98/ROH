import groovy.yaml.YamlSlurper

def yamlSlurper = new YamlSlurper()
def configFile = new File("${launchDir}/param_files/main.yaml")
def mainyaml = yamlSlurper.parse(configFile)

params.main = mainyaml.main
params.slurm = mainyaml.slurm
params.vcf = mainyaml.vcf
params.apptainer = mainyaml.apptainer
singularity.enabled = params.main.apptainer

includeConfig "subworkflows/dnaseq/dnaseq.config"
includeConfig "subworkflows/ROH/ROH.config"

def image(name) {
	(params.main.apptainer && params.apptainer[name]) ? "${params.apptainer.path}/${params.apptainer[name]}" : null
}

profiles {

	slurm {

		process {
			executor = 'slurm'
		}

		process {

			withLabel: 'multiqc' {
				container = image("multiqc")
				memory = mainyaml.multiqc.resources.slurm.memory
				time = mainyaml.multiqc.resources.slurm.time
				cpus = mainyaml.multiqc.resources.slurm.cpus
				clusterOptions = "--account=${params.slurm.account} --output=multiqc.out --mail-type=END --mail-user=${params.slurm.email} --job-name=multiqc"	
			}
		}

		process {

			withLabel: 'versions' {
				container = image("versions")
				memory = mainyaml.version.resources.slurm.memory
				time = mainyaml.version.resources.slurm.time
				cpus = mainyaml.version.resources.slurm.cpus
				clusterOptions = "--account=${params.slurm.account} --output=versions.out --mail-type=END --mail-user=${params.slurm.email} --job-name=merge_version"	
			}
		}
	}

	local {

		process {
			executor = 'local'
		}

		process {

			withLabel: 'multiqc' {
				container = image("multiqc")
				memory = mainyaml.multiqc.resources.local.memory
				time = mainyaml.multiqc.resources.local.time
				cpus = mainyaml.multiqc.resources.local.cpus
			}
		}

		process {

			withLabel: 'versions' {
				container = image("versions")
				memory = mainyaml.version.resources.local.memory
				time = mainyaml.version.resources.local.time
				cpus = mainyaml.version.resources.local.cpus
			}
		}
	}
}
