import groovy.yaml.YamlSlurper

def yamlSlurper = new YamlSlurper()
def configFile = new File("${launchDir}/param_files/dnaseq.yaml")
def dnayaml = yamlSlurper.parse(configFile)

params.settings = dnayaml.settings

profiles {

	base {
		withLabel: 'fastqc' {
			memory = 1.GB
			time = '40m'
			cpus = 2
		}

		withLabel: 'trim_galore' {
			memory = 16.GB
			time = '3h'
			cpus = 8
		}

		withLabel: 'bwa' {
			memory = 16.GB
			time = '8h'
			cpus = 16

		}

		withLabel: 'markdup' {
			memory = 32.GB
			time = '4h'
			cpus = 4
		}

		withLabel: 'bqsr' {
			memory = 32.GB
			time = '2h'
			cpus = 4
		}

		withLabel: 'gvcf' {
			memory = 15.GB
			time = '8h'
			cpus = 2
		}

		withLabel: 'gvcf_merge' {
			memory = 45.GB
			time = '8h'
			cpus = 8
		}
	}

	slurm {
		process {

			withLabel: 'fastqc' {
				clusterOptions = "--account=${params.main.account} --output=fastqc.out --mail-type=END --mail-user=${params.main.email} --job-name=fastqc"	
			}

			withLabel: 'trim_galore' {
				clusterOptions = "--account=${params.main.account} --output=trim.out --mail-type=END --mail-user=${params.main.email} --job-name=trim"
			}

			withLabel: 'bwa' {
				clusterOptions = "--account=${params.main.account} --output=bwa.out --mail-type=END --mail-user=${params.main.email} --job-name=bwa"
			}

			withLabel: 'markdup' {
				clusterOptions = "--account=${params.main.account} --output=markdup.out --mail-type=END --mail-user=${params.main.email} --job-name=markdup"
			}

			withLabel: 'bqsr' {
				clusterOptions = "--account=${params.main.account} --output=bqsr.out --mail-type=END --mail-user=${params.main.email} --job-name=bqsr"
			}

			withLabel: 'gvcf' {
				clusterOptions = "--account=${params.main.account} --output=gvcf.out --mail-type=END --mail-user=${params.main.email} --job-name=gvcf"
			}

			withLabel: 'gvcf_merge' {
				clusterOptions = "--account=${params.main.account} --output=gvcf_merge.out --mail-type=END --mail-user=${params.main.email} --job-name=gvcf_merge"
			}
		}
	}

}
